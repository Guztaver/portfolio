{
  "name": "gustavo-muniz-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive terminal-style portfolio built with Next.js and TypeScript",
  "author": "Gustavo Muniz <contact@gustavoanjos.com>",
  "homepage": "https://gustavoanjos.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/guztaver/portfolio"
  },
  "keywords": [
    "portfolio",
    "terminal",
    "nextjs",
    "typescript",
    "react",
    "developer"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:standard": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "preview": "npm run build && npm run start",
    "clean": "rm -rf .next node_modules/.cache",
    "export": "next build && next export"
  },
  "dependencies": {
    "@vercel/speed-insights": "^1.3.1",
    "jspdf": "^3.0.4",
    "next": "16.2.3",
    "react": "19.1.0",
